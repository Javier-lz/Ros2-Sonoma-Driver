<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="four_wheels_robot">
       <xacro:property name="PI" value="3.141592653589793"/>
        
    <xacro:property name="chasis_width" value="423.3"/>
    <xacro:property name="chasis_length" value="183.6"/>
    <xacro:property name="chasis_height" value="150"/>
    <xacro:property name="chasis_mass" value="1"/>

    <xacro:property name="wheel_mass" value="11"/>
    <xacro:property name="wheel_radius" value="35.5"/>
    <xacro:property name="wheel_length" value="22.5"/>

    <xacro:property name="camera_width" value="5"/>
    <xacro:property name="camera_height" value="10"/>
    <xacro:property name="camera_length" value="10"/>
    <xacro:property name="camera_mass" value="1.0"/>
    
    <xacro:include filename="$(find four_wheels_robot)/urdf/inertial_commons.xacro"/>
     <xacro:include filename="$(find four_wheels_robot)/urdf/camera.xacro"/>
  <!-- Chassis -->
   <link name="base_footprint">
     
   </link>
    <link name="body_link">
        <visual>
        <geometry>
            <box size="${chasis_width} ${chasis_length} ${chasis_height}"/>
        </geometry>
        <material name="blue">
            <color rgba="0 0 1 1"/>
        </material>
        </visual>
        <collision>
        <geometry>
            <box size="${chasis_width} ${chasis_length} ${chasis_height}"/>
        </geometry>
        </collision>

        <xacro:inertial_box mass="${chasis_mass}" x="${chasis_width}" y="${chasis_length}" z="${chasis_height}">

            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_box>
        
    </link> 
    <joint name="body_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="body_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>


  <!-- Wheels -->
   <xacro:macro name="wheel" params="name x y z">
        <joint name="${name}_joint" type="continuous" >
            <parent link="body_link"/>
            <child  link="${name}_link" />
            <origin xyz="${x} ${y} ${z}" rpy="0 0 0" />
            <axis xyz="0 1 0"/>
        </joint>
        <link name="${name}_link">
            <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_length}" radius="${wheel_radius}">
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </xacro:inertial_cylinder>
            <visual>
                <origin rpy="${PI/2} 0 0" xyz="0 0 0"/>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                
                <material name="black">
                    <color rgba="0 0 0 1"/>
                </material>
            </visual>
            <collision>
                <origin rpy="${PI/2} 0 0" xyz="0 0 0"/>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
            </collision>
        </link>
    </xacro:macro>
    <xacro:wheel name="front_left" x="${chasis_width*0.3}" y="${chasis_length/2 + wheel_length/2*0.8}" z="${-chasis_height/2*1.3+wheel_radius}"/>
    <xacro:wheel name="front_right" x="${chasis_width*0.3}" y="${-chasis_length/2 - wheel_length/2*0.8}" z="${-chasis_height/2*1.3+wheel_radius}"/>
    <xacro:wheel name="rear_left" x="${-chasis_width*0.3}" y="${chasis_length/2 + wheel_length/2*0.8}" z="${-chasis_height/2*1.3+wheel_radius}"/>
    <xacro:wheel name="rear_right" x="${-chasis_width*0.3}" y="${-chasis_length/2 - wheel_length/2*0.8}" z="${-chasis_height/2*1.3+wheel_radius}"/>


</robot>